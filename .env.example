# Live mode only. Replay mode (the default) needs none of this.
#
#   EVAL_LIVE unset/0  → runner + judge read recorded fixtures/  (no key, no cost)
#   EVAL_LIVE=1        → runner + judge call the real Anthropic API
#
# Copy to .env and fill in to use live mode:
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides (defaults shown):
# EVAL_TARGET_MODEL=claude-opus-4-8   # the model being evaluated
# EVAL_JUDGE_MODEL=claude-opus-4-8    # the LLM-as-judge
